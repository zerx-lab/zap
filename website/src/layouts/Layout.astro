---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { t, type Locale } from '../i18n';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
}
const { locale, title, description } = Astro.props;
const dict = t(locale);
const pageTitle = title ?? dict.meta.title;
const pageDescription = description ?? dict.meta.description;
---

<!doctype html>
<html lang={locale} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#05050a" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="alternate" hreflang="zh-CN" href="/" />
    <link rel="alternate" hreflang="en" href="/en/" />
    <script is:inline>
      // 浏览器语言自动检测:中文留中文页,其他语言跳 /en/
      // 用户手动点切换器后记忆偏好,后续不再自动重定向
      (function () {
        try {
          var KEY = 'ow-lang';
          var path = location.pathname;
          var isEnPage = /^\/en(\/|$)/.test(path);
          document.addEventListener('click', function (e) {
            var a = e.target && e.target.closest && e.target.closest('a[data-locale-switch]');
            if (a) {
              try { localStorage.setItem(KEY, a.getAttribute('data-locale-switch')); } catch (_) {}
            }
          });
          if (localStorage.getItem(KEY)) return;
          if (isEnPage) return;
          var lang = (navigator.language || (navigator.languages && navigator.languages[0]) || '').toLowerCase();
          if (lang && !lang.startsWith('zh')) {
            try { localStorage.setItem(KEY, 'en'); } catch (_) {}
            var target = '/en' + (path === '/' ? '/' : path);
            location.replace(target);
          }
        } catch (_) {}
      })();
    </script>
  </head>
  <body class="min-h-screen overflow-x-hidden bg-ink-950 font-sans">
    <div class="pointer-events-none fixed inset-0 -z-10 bg-gradient-hero"></div>
    <div class="pointer-events-none fixed inset-x-0 top-0 -z-10 h-[760px] grid-bg opacity-45"></div>
    <div aria-hidden="true" class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
      <div class="absolute -top-56 left-1/2 h-[620px] w-[940px] -translate-x-1/2 rounded-full bg-brand-500/20 blur-[170px]"></div>
      <div class="absolute top-[28rem] -left-40 h-[420px] w-[420px] rounded-full bg-accent-pink/10 blur-[130px]"></div>
      <div class="absolute top-[34rem] -right-40 h-[420px] w-[420px] rounded-full bg-accent-cyan/10 blur-[130px]"></div>
    </div>
    <div aria-hidden="true" class="pointer-events-none fixed inset-x-0 top-0 -z-10 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>

    <Header locale={locale} />
    <main class="relative z-0">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
