---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { t, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);
---

<!doctype html>
<html lang={locale} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{dict.meta.title}</title>
    <meta name="description" content={dict.meta.description} />
    <meta property="og:title" content={dict.meta.title} />
    <meta property="og:description" content={dict.meta.description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#06070b" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" hreflang="zh-CN" href="/" />
    <link rel="alternate" hreflang="en" href="/en/" />
  </head>
  <body class="min-h-screen overflow-x-hidden bg-ink-950 font-sans">
    <!-- Decorative background layers -->
    <div class="pointer-events-none fixed inset-0 -z-10 bg-gradient-hero"></div>
    <div class="pointer-events-none fixed inset-x-0 top-0 -z-10 h-[700px] grid-bg opacity-50"></div>

    <!-- Single subtle accent orb -->
    <div aria-hidden="true" class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
      <div class="absolute -top-40 left-1/2 h-[480px] w-[680px] -translate-x-1/2 rounded-full bg-brand-500/12 blur-[140px]"></div>
    </div>

    <!-- Top hairline -->
    <div aria-hidden="true" class="pointer-events-none fixed inset-x-0 top-0 -z-10 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

    <Header locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
