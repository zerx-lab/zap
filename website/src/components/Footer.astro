---
import { t, type Locale, localizedPath } from '../i18n';
interface Props { locale: Locale }
const { locale } = Astro.props;
const dict = t(locale);
const year = new Date().getFullYear();
const roadmapHref = localizedPath(locale, '/roadmap');
---

<footer class="relative mt-12 border-t border-white/10 bg-ink-950/80 backdrop-blur-xl">
  <div class="container-page py-14 lg:py-16">
    <div class="grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <a href={localizedPath(locale, '/')} class="inline-flex items-center gap-3">
          <span class="flex h-10 w-10 items-center justify-center rounded-xl border border-white/10 bg-white/[0.06] shadow-card">
            <img src="/logo-mono.svg" alt="OpenWarp" class="h-7 w-7 object-contain" />
          </span>
          <span class="font-display text-lg font-semibold tracking-tight text-white">OpenWarp</span>
        </a>
        <p class="mt-5 max-w-md text-sm leading-7 text-zinc-400">{dict.footer.rights}</p>
        <p class="mt-5 font-mono text-xs text-zinc-600">© {year} OpenWarp · AGPL-3.0 / MIT</p>
      </div>

      <div class="grid gap-8 sm:grid-cols-3 lg:col-span-7">
        <div>
          <h4 class="text-xs font-semibold uppercase tracking-[0.22em] text-zinc-500">{dict.footer.project}</h4>
          <ul class="mt-4 space-y-3 text-sm">
            <li><a class="text-zinc-400 transition hover:text-white" href="#features">{dict.nav.features}</a></li>
            <li><a class="text-zinc-400 transition hover:text-white" href="#providers">{dict.nav.providers}</a></li>
            <li><a class="text-zinc-400 transition hover:text-white" href={roadmapHref}>{dict.footer.roadmap}</a></li>
          </ul>
        </div>

        <div>
          <h4 class="text-xs font-semibold uppercase tracking-[0.22em] text-zinc-500">{dict.footer.community}</h4>
          <ul class="mt-4 space-y-3 text-sm">
            <li><a class="text-zinc-400 transition hover:text-white" href="https://github.com/zerx-lab/warp/tree/openWarp">GitHub</a></li>
            <li><a class="text-zinc-400 transition hover:text-white" href="https://github.com/zerx-lab/warp/discussions">{dict.footer.discussions}</a></li>
            <li><a class="text-zinc-400 transition hover:text-white" href="https://github.com/zerx-lab/warp/issues">{dict.footer.issues}</a></li>
          </ul>
        </div>

        <div>
          <h4 class="text-xs font-semibold uppercase tracking-[0.22em] text-zinc-500">{dict.footer.legal}</h4>
          <ul class="mt-4 space-y-3 text-sm">
            <li><a class="text-zinc-400 transition hover:text-white" href="https://github.com/zerx-lab/warp/blob/openWarp/LICENSE-AGPL">{dict.footer.license}</a></li>
            <li><a class="text-zinc-400 transition hover:text-white" href="#faq">{dict.footer.privacy}</a></li>
            <li><a class="text-zinc-400 transition hover:text-white" href="#cta">{dict.cta.button}</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-3 border-t border-white/10 pt-6 text-xs text-zinc-500 sm:flex-row sm:items-center">
      <p>Built with Astro · Tailwind · Framer Motion</p>
      <p class="font-mono text-zinc-600">openwarp.dev</p>
    </div>
  </div>
</footer>
