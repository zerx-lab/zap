---
import { t, type Locale } from '../i18n';
import CommandCard from './CommandCard.tsx';
interface Props { locale: Locale }
const { locale } = Astro.props;
const d = t(locale);
---

<section id="cta" class="relative py-24 lg:py-32">
  <div class="container-page">
    <div class="surface-card isolate overflow-hidden px-5 py-12 text-center sm:px-8 sm:py-16 lg:px-14 lg:py-20">
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(45%_60%_at_50%_0%,rgba(141,125,255,0.24),transparent_70%)]"></div>
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 grid-bg opacity-[0.08]"></div>

      <span class="section-eyebrow">OpenWarp</span>
      <h3 class="mx-auto mt-5 max-w-4xl font-display text-[34px] font-semibold leading-[1.05] tracking-[-0.06em] text-gradient sm:text-6xl lg:text-7xl">
        {d.cta.title}
      </h3>
      <p class="mx-auto mt-5 max-w-2xl text-base leading-8 text-zinc-400 sm:text-lg">
        {d.cta.desc}
      </p>

      <div class="mx-auto mt-9 max-w-2xl rounded-[28px] border border-white/10 bg-black/30 p-3 shadow-card backdrop-blur-xl sm:p-4">
        <div class="flex items-center justify-between px-2 pb-3">
          <span class="text-[11px] font-semibold uppercase tracking-[0.2em] text-zinc-500">{d.cta.command_label}</span>
          <span class="font-mono text-[11px] text-zinc-600">~/dev</span>
        </div>
        <CommandCard
          client:load
          command={d.cta.command}
          copyLabel={d.cta.copy}
          copiedLabel={d.cta.copied}
        />
      </div>

      <div class="mx-auto mt-6 flex max-w-3xl flex-wrap justify-center gap-2">
        {d.cta.steps.map((s, i) => (
          <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5 font-mono text-[11px] text-zinc-400">
            <span class="flex h-5 w-5 items-center justify-center rounded-full bg-white/[0.06] text-[10px] text-zinc-300">{i + 1}</span>
            {s}
          </span>
        ))}
      </div>

      <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="https://github.com/zerx-lab/warp/tree/openWarp" target="_blank" rel="noreferrer" class="btn-primary w-full sm:w-auto">
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.18c-3.2.7-3.87-1.37-3.87-1.37-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.15 1.17.91-.25 1.89-.38 2.86-.39.97.01 1.95.14 2.86.39 2.19-1.48 3.15-1.17 3.15-1.17.62 1.59.23 2.76.11 3.05.74.8 1.18 1.82 1.18 3.08 0 4.42-2.69 5.4-5.25 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/></svg>
          {d.cta.button}
        </a>
        <a href="#features" class="btn-ghost w-full sm:w-auto">
          {d.nav.features}
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</section>
