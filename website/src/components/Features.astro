---
import { t, type Locale } from '../i18n';

interface Props { locale: Locale }
const { locale } = Astro.props;
const d = t(locale);
const items = d.features.items;
const primaryProvider = d.providers.tabs[0];
const featureCards = [
  { item: items[1], eyebrow: d.bento.templates.tag, glyph: '{}', detail: d.bento.templates.preview },
  { item: items[2], eyebrow: d.bento.i18n.tag, glyph: 'Aa', detail: d.bento.i18n.pills.join(' · ') },
  { item: items[4], eyebrow: d.bento.warp.tag, glyph: '⌘', detail: d.bento.warp.chips.join(' · ') },
  { item: items[5], eyebrow: d.bento.opensource.tag, glyph: '↗', detail: d.bento.opensource.license.join(' · ') },
];
---

<section id="features" class="relative py-24 lg:py-32">
  <div class="container-page">
    <div class="grid items-end gap-8 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <span class="section-eyebrow">{d.features.eyebrow}</span>
        <h2 class="section-heading mt-5 max-w-4xl">
          {d.features.title}
        </h2>
      </div>
      <p class="section-copy lg:col-span-5 lg:pb-2">
        {items[4].desc}
      </p>
    </div>

    <div class="mt-14 grid gap-5 lg:grid-cols-12">
      <article class="surface-card ring-gradient isolate overflow-hidden p-5 sm:p-7 lg:col-span-8">
        <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(55%_70%_at_78%_28%,rgba(141,125,255,0.18),transparent_72%)]"></div>
        <div class="grid gap-8 lg:grid-cols-[0.88fr_1.12fr] lg:items-stretch">
          <div class="flex flex-col justify-between">
            <div>
              <span class="text-[11px] font-semibold uppercase tracking-[0.22em] text-brand-300">{d.bento.byop.tag}</span>
              <h3 class="mt-4 font-display text-3xl font-semibold leading-tight tracking-[-0.04em] text-white sm:text-4xl">
                {items[0].title}
              </h3>
              <p class="mt-4 text-sm leading-7 text-zinc-400 sm:text-base">
                {items[0].desc}
              </p>
            </div>

            <div class="mt-8 grid gap-2">
              {d.providers.bullets.slice(0, 3).map((b) => (
                <div class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/[0.04] px-4 py-3 text-sm text-zinc-300">
                  <span class="h-1.5 w-1.5 rounded-full bg-accent-lime shadow-[0_0_14px_rgba(185,255,90,0.8)]"></span>
                  <span>{b.replace('✓ ', '')}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="rounded-[26px] border border-white/10 bg-black/35 p-3 shadow-card backdrop-blur-xl">
            <div class="flex items-center justify-between border-b border-white/10 px-2 pb-3">
              <div class="flex items-center gap-1.5">
                <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f57]"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-[#febc2e]"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-[#28c840]"></span>
              </div>
              <span class="font-mono text-[10px] text-zinc-600">~/.config/openwarp.toml</span>
            </div>

            <div class="mt-4 flex flex-wrap gap-2">
              {d.providers.tabs.map((provider, index) => (
                <span class:list={[
                  'inline-flex items-center gap-2 rounded-full border px-3 py-1.5 text-[11px] font-medium transition',
                  index === 0
                    ? 'border-brand-300/40 bg-brand-400/15 text-white'
                    : 'border-white/10 bg-white/[0.04] text-zinc-500',
                ]}>
                  <span class:list={[
                    'h-1.5 w-1.5 rounded-full',
                    index === 0 ? 'bg-accent-lime' : 'bg-zinc-700',
                  ]}></span>
                  {provider.name}
                </span>
              ))}
            </div>

            <div class="mt-5 grid gap-3">
              {[
                [d.providers.fields.name, `${primaryProvider.name} · ${primaryProvider.tag}`],
                [d.providers.fields.base_url, primaryProvider.baseUrl],
                [d.providers.fields.model, primaryProvider.model],
              ].map(([label, value]) => (
                <div class="grid gap-1.5">
                  <span class="text-[10px] font-semibold uppercase tracking-[0.18em] text-zinc-600">{label}</span>
                  <span class="rounded-2xl border border-white/10 bg-ink-950/80 px-3 py-2.5 font-mono text-[12px] text-zinc-200">{value}</span>
                </div>
              ))}
            </div>

            <div class="mt-4 rounded-2xl border border-white/10 bg-white/[0.035] p-4">
              <div class="flex items-center justify-between gap-3">
                <span class="text-[10px] font-semibold uppercase tracking-[0.18em] text-zinc-600">{d.providers.fields.prompt}</span>
                <span class="rounded-full bg-accent-lime/10 px-2 py-0.5 font-mono text-[10px] text-accent-lime ring-1 ring-accent-lime/20">{d.terminal.status.ready}</span>
              </div>
              <pre class="mt-3 overflow-hidden font-mono text-[11.5px] leading-6 text-zinc-400"><span class="text-accent-pink">{'{%'} </span>if locale<span class="text-accent-pink"> {'%}'}</span>
Reply in <span class="text-accent-cyan">{'{{'}</span> locale <span class="text-accent-cyan">{'}}'}</span>
<span class="text-accent-pink">{'{%'} </span>endif<span class="text-accent-pink"> {'%}'}</span></pre>
            </div>
          </div>
        </div>
      </article>

      <article class="surface-card ring-gradient isolate overflow-hidden p-6 sm:p-7 lg:col-span-4">
        <div aria-hidden="true" class="pointer-events-none absolute -right-16 -top-20 -z-10 h-52 w-52 rounded-full bg-accent-lime/10 blur-3xl"></div>
        <div class="flex items-start justify-between gap-4">
          <div>
            <span class="text-[11px] font-semibold uppercase tracking-[0.22em] text-zinc-500">{d.bento.privacy.tag}</span>
            <h3 class="mt-4 font-display text-3xl font-semibold tracking-[-0.04em] text-white">
              {items[3].title}
            </h3>
          </div>
          <span class="flex h-12 w-12 items-center justify-center rounded-2xl border border-brand-300/20 bg-brand-400/10 text-brand-200">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3 4 6v6c0 5 3.5 8.5 8 9 4.5-.5 8-4 8-9V6l-8-3Z"/>
              <path d="M9 12h6M12 9v6"/>
            </svg>
          </span>
        </div>
        <p class="mt-4 text-sm leading-7 text-zinc-400">{items[3].desc}</p>

        <div class="mt-8 rounded-3xl border border-white/10 bg-black/25 p-4">
          <div class="flex items-center justify-between text-[11px] uppercase tracking-[0.18em] text-zinc-600">
            <span>{d.stats.items[3].label}</span>
            <span class="font-mono text-accent-lime">100%</span>
          </div>
          <div class="mt-3 h-2 overflow-hidden rounded-full bg-white/[0.06]">
            <div class="h-full rounded-full bg-gradient-to-r from-accent-lime via-brand-300 to-accent-cyan"></div>
          </div>
        </div>

        <ul class="mt-4 grid gap-2">
          {d.bento.privacy.bullets.map((b) => (
            <li class="flex items-center justify-between gap-3 rounded-2xl border border-white/10 bg-white/[0.035] px-4 py-3 text-sm text-zinc-300">
              <span>{b}</span>
              <span class="h-1.5 w-1.5 rounded-full bg-accent-lime"></span>
            </li>
          ))}
        </ul>
      </article>

      {featureCards.map((card, index) => (
        <article class="surface-soft ring-gradient isolate min-h-[220px] overflow-hidden p-6 lg:col-span-3">
          <div aria-hidden="true" class="pointer-events-none absolute -right-12 -top-12 -z-10 h-32 w-32 rounded-full bg-brand-400/10 blur-3xl"></div>
          <div class="flex items-center justify-between gap-4">
            <span class="text-[11px] font-semibold uppercase tracking-[0.2em] text-zinc-500">
              {String(index + 2).padStart(2, '0')} · {card.eyebrow}
            </span>
            <span class="flex h-10 w-10 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.04] font-mono text-sm text-brand-200">
              {card.glyph}
            </span>
          </div>
          <h3 class="mt-5 font-display text-xl font-semibold tracking-[-0.03em] text-white">
            {card.item.title}
          </h3>
          <p class="mt-3 text-sm leading-7 text-zinc-400">{card.item.desc}</p>
          <p class="mt-6 border-t border-white/10 pt-4 font-mono text-[11px] leading-6 text-zinc-500">
            {card.detail}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
