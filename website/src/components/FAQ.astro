---
import { t, type Locale } from '../i18n';
interface Props { locale: Locale }
const { locale } = Astro.props;
const d = t(locale);
---

<section id="faq" class="relative py-24 lg:py-28">
  <div class="container-page">
    <div class="grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-4">
        <div class="sticky top-32">
          <span class="section-eyebrow">{d.faq.eyebrow}</span>
          <h2 class="mt-5 font-display text-3xl font-semibold tracking-[-0.04em] text-white sm:text-5xl">
            {d.faq.title}
          </h2>
        </div>
      </div>

      <div class="space-y-3 lg:col-span-8">
        {d.faq.items.map((it, i) => (
          <details class="group surface-card overflow-hidden open:bg-white/[0.055]" open={i === 0}>
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-5 text-left sm:px-7">
              <span class="text-base font-medium text-zinc-100 sm:text-lg">{it.q}</span>
              <span class="flex h-8 w-8 flex-none items-center justify-center rounded-full border border-white/10 text-zinc-400 transition group-open:rotate-45 group-open:border-brand-300/40 group-open:text-white">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
              </span>
            </summary>
            <div class="border-t border-white/10 px-5 pb-6 pt-4 text-sm leading-7 text-zinc-400 sm:px-7">
              {it.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>
