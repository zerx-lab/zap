---
import { t, type Locale } from '../i18n';

interface Props { locale: Locale }
const { locale } = Astro.props;
const d = t(locale);
const r = d.roadmap;

const statusStyles: Record<string, { dot: string; chip: string; label: string }> = {
  shipped: {
    dot: 'bg-emerald-400',
    chip: 'border-emerald-400/30 bg-emerald-400/[0.08] text-emerald-200',
    label: r.legend.shipped,
  },
  in_progress: {
    dot: 'bg-brand-400 animate-pulse',
    chip: 'border-brand-400/30 bg-brand-400/[0.08] text-brand-200',
    label: r.legend.in_progress,
  },
  planned: {
    dot: 'bg-zinc-500',
    chip: 'border-white/10 bg-white/[0.03] text-zinc-400',
    label: r.legend.planned,
  },
};
---

<section class="relative py-24 lg:py-32">
  <div class="container-page">
    <!-- Header -->
    <div class="mx-auto max-w-2xl text-center">
      <span class="chip">{r.eyebrow}</span>
      <h1 class="mt-5 font-display text-3xl font-semibold tracking-tight text-white sm:text-4xl lg:text-5xl">
        {r.title}
      </h1>
      <p class="mt-5 text-base leading-relaxed text-zinc-400">{r.subtitle}</p>

      <!-- Legend -->
      <div class="mt-7 inline-flex flex-wrap items-center justify-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5 text-[11.5px]">
        {(['shipped', 'in_progress', 'planned'] as const).map((s) => (
          <span class="inline-flex items-center gap-1.5 px-2 text-zinc-300">
            <span class={`h-1.5 w-1.5 rounded-full ${statusStyles[s].dot}`}></span>
            {statusStyles[s].label}
          </span>
        ))}
      </div>
    </div>

    <!-- Tracks -->
    <div class="mx-auto mt-16 grid max-w-6xl grid-cols-1 gap-5 lg:grid-cols-3">
      {r.tracks.map((track) => (
        <article id={track.id} class="ring-gradient relative flex flex-col overflow-hidden rounded-2xl border border-white/5 bg-white/[0.02] p-6 sm:p-7">
          <span class="text-[11px] font-medium uppercase tracking-[0.16em] text-brand-300">{track.eyebrow}</span>
          <h2 class="mt-3 font-display text-xl font-semibold tracking-tight text-white">{track.title}</h2>
          <p class="mt-2 text-[13px] leading-relaxed text-zinc-400">{track.summary}</p>

          <!-- Progress bar -->
          <div class="mt-5">
            <div class="flex items-center justify-between text-[11px] uppercase tracking-widest text-zinc-500">
              <span>{r.progress_label}</span>
              <span class="font-mono text-zinc-300">{track.progress}%</span>
            </div>
            <div class="mt-2 h-1 overflow-hidden rounded-full bg-white/[0.05]">
              <div
                class="h-full rounded-full bg-gradient-to-r from-brand-500 to-brand-300"
                style={`width:${track.progress}%`}
              ></div>
            </div>
          </div>

          <!-- Items -->
          <ul class="mt-6 space-y-2.5">
            {track.items.map((it) => {
              const s = statusStyles[it.status] ?? statusStyles.planned;
              return (
                <li class="flex items-start gap-2.5">
                  <span class={`mt-1 inline-flex shrink-0 items-center gap-1 rounded-full border px-1.5 py-px text-[10px] font-medium uppercase tracking-wider ${s.chip}`}>
                    <span class={`h-1 w-1 rounded-full ${s.dot}`}></span>
                    {s.label}
                  </span>
                  <span class="text-[13px] leading-relaxed text-zinc-300">{it.text}</span>
                </li>
              );
            })}
          </ul>
        </article>
      ))}
    </div>

    <!-- Footnote / CTA -->
    <div class="mx-auto mt-16 max-w-3xl rounded-2xl border border-white/5 bg-white/[0.02] p-6 sm:p-8">
      <h3 class="font-display text-lg font-semibold text-white">{r.footnote_title}</h3>
      <p class="mt-3 text-[13.5px] leading-relaxed text-zinc-400">{r.footnote_body}</p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a
          href="https://github.com/zerx-lab/warp/tree/openWarp"
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-white/10 bg-white/[0.04] px-4 py-2 text-[13px] text-white transition hover:bg-white/[0.07]"
        >
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.18c-3.2.7-3.87-1.37-3.87-1.37-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.15 1.17.91-.25 1.89-.38 2.86-.39.97.01 1.95.14 2.86.39 2.19-1.48 3.15-1.17 3.15-1.17.62 1.59.23 2.76.11 3.05.74.8 1.18 1.82 1.18 3.08 0 4.42-2.69 5.4-5.25 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/></svg>
          {r.cta_repo}
        </a>
        <a
          href="https://github.com/zerx-lab/warp/issues"
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-brand-500/30 bg-brand-500/[0.08] px-4 py-2 text-[13px] text-brand-100 transition hover:bg-brand-500/[0.14]"
        >
          {r.cta_issues}
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</section>
