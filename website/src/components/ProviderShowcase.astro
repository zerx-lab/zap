---
import { t, type Locale } from '../i18n';
import ProviderTabs from './ProviderTabs.tsx';

interface Props { locale: Locale }
const { locale } = Astro.props;
const d = t(locale);

const providerLogos = [
  'OpenAI', 'Anthropic', 'DeepSeek', 'Qwen', 'Ollama', 'Groq',
  'Together', 'Mistral', 'Gemini', 'LM Studio', 'OpenRouter', 'Azure',
];
const marqueeItems = [...providerLogos, ...providerLogos];
---

<section id="providers" class="relative py-24 lg:py-32">
  <div class="container-page">
    <div class="grid gap-8 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <span class="section-eyebrow">{d.providers.eyebrow}</span>
        <h2 class="section-heading mt-5">
          {d.providers.title}
        </h2>
        <p class="section-copy mt-6">
          {d.providers.subtitle}
        </p>

        <ul class="mt-8 grid gap-3">
          {d.providers.bullets.map((b) => (
            <li class="flex items-start gap-3 rounded-2xl border border-white/10 bg-white/[0.035] px-4 py-3.5 text-sm leading-6 text-zinc-300">
              <span class="mt-2 h-1.5 w-1.5 flex-none rounded-full bg-brand-300"></span>
              <span>{b}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="lg:col-span-7">
        <div class="surface-card overflow-hidden p-2">
          <ProviderTabs
            client:visible
            tabs={d.providers.tabs}
            labels={{
              name: d.providers.fields.name,
              protocol: d.providers.fields.protocol,
              base_url: d.providers.fields.base_url,
              endpoint: d.providers.fields.endpoint,
              api_key: d.providers.fields.api_key,
              model: d.providers.fields.model,
            }}
          />
        </div>

        <div class="mt-4 rounded-[28px] border border-white/10 bg-black/25 p-5 shadow-card backdrop-blur-xl">
          <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-zinc-500">{d.providers.fields.prompt}</p>
          <pre class="mt-4 overflow-x-auto rounded-2xl border border-white/10 bg-ink-950/80 p-4 font-mono text-[12px] leading-7 text-zinc-300"><span class="text-accent-pink">{'{%'} </span>if user.role<span class="text-accent-pink"> {'%}'}</span>
You are an expert <span class="text-accent-cyan">{'{{'}</span> user.role <span class="text-accent-cyan">{'}}'}</span>.
<span class="text-accent-pink">{'{%'} </span>endif<span class="text-accent-pink"> {'%}'}</span>
Reply in <span class="text-accent-cyan">{'{{'}</span> locale <span class="text-accent-cyan">{'}}'}</span>.</pre>
        </div>
      </div>
    </div>

    <div class="marquee-mask mt-16 overflow-hidden">
      <div class="marquee gap-4">
        {marqueeItems.map((p) => (
          <div class="flex h-14 min-w-[172px] items-center justify-center rounded-2xl border border-white/10 bg-white/[0.035] px-6 text-sm font-semibold tracking-tight text-zinc-400 shadow-card">
            {p}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
