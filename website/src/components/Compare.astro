---
import { t, type Locale } from '../i18n';
import HowItWorks from './HowItWorks.tsx';
interface Props { locale: Locale }
const { locale } = Astro.props;
const d = t(locale);
---

<section id="how" class="relative py-24 lg:py-32">
  <div class="container-page">
    <div class="grid items-end gap-8 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <span class="section-eyebrow">{d.how.eyebrow}</span>
        <h2 class="section-heading mt-5 max-w-4xl">
          {d.how.title}
        </h2>
      </div>
      <p class="section-copy lg:col-span-5 lg:pb-2">
        {d.how.subtitle}
      </p>
    </div>

    <HowItWorks client:visible steps={d.how.steps} />
  </div>
</section>
