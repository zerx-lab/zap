---
import { t, type Locale } from '../i18n';
import HowItWorks from './HowItWorks.tsx';
interface Props { locale: Locale }
const { locale } = Astro.props;
const d = t(locale);
---

<section id="how" class="relative py-24 lg:py-32">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center">
      <span class="chip">{d.how.eyebrow}</span>
      <h2 class="mt-5 font-display text-3xl font-semibold tracking-tight text-white sm:text-4xl lg:text-5xl">
        {d.how.title}
      </h2>
      <p class="mt-5 text-zinc-400">{d.how.subtitle}</p>
    </div>

    <HowItWorks client:visible steps={d.how.steps} />
  </div>
</section>
