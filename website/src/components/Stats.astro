---
import { t, type Locale } from '../i18n';
interface Props { locale: Locale }
const { locale } = Astro.props;
const d = t(locale);
---

<section class="relative py-10">
  <div class="container-page">
    <div class="surface-card relative overflow-hidden">
      <div class="grid grid-cols-2 divide-y divide-white/5 sm:grid-cols-4 sm:divide-x sm:divide-y-0">
        {d.stats.items.map((it) => (
          <div class="relative flex flex-col items-center justify-center gap-1 px-6 py-7">
            <span class="font-display text-3xl font-semibold tracking-tight text-white sm:text-4xl">
              {it.value}
            </span>
            <span class="text-[12px] uppercase tracking-[0.16em] text-zinc-500">{it.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
