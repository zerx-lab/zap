---
import { t, type Locale } from '../i18n';
import Terminal from './Terminal.tsx';

interface Props { locale: Locale }
const { locale } = Astro.props;
const d = t(locale);

const trustLogos = ['OpenAI', 'Anthropic', 'DeepSeek', 'Qwen', 'Ollama', 'Groq'];
---

<section class="relative isolate overflow-hidden pb-16 pt-16 sm:pt-20 lg:pb-24 lg:pt-24">
  <div class="container-page">
    <div class="mx-auto max-w-5xl text-center">
      <span class="glass-pill">
        <span class="ping-dot relative inline-flex h-1.5 w-1.5">
          <span class="absolute inset-0 rounded-full bg-accent-lime opacity-75 animate-ping"></span>
          <span class="relative h-1.5 w-1.5 rounded-full bg-accent-lime"></span>
        </span>
        {d.hero.badge}
      </span>

      <h1 class="mt-7 font-display text-[42px] font-semibold leading-[1.08] tracking-[-0.07em] text-gradient sm:text-[76px] lg:text-[104px]">
        <span>{d.hero.title_1}</span>
        <span class="block text-accent">{d.hero.title_em}</span>
        <span>{d.hero.title_2}</span>
      </h1>

      <p class="mx-auto mt-7 max-w-3xl text-base leading-8 text-zinc-300 sm:text-xl sm:leading-9">
        {d.hero.subtitle}
      </p>

      <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="https://github.com/zerx-lab/warp" target="_blank" rel="noreferrer" class="btn-primary group w-full sm:w-auto">
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.18c-3.2.7-3.87-1.37-3.87-1.37-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.15 1.17.91-.25 1.89-.38 2.86-.39.97.01 1.95.14 2.86.39 2.19-1.48 3.15-1.17 3.15-1.17.62 1.59.23 2.76.11 3.05.74.8 1.18 1.82 1.18 3.08 0 4.42-2.69 5.4-5.25 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/></svg>
          {d.hero.cta_primary}
        </a>
        <a href="#providers" class="btn-ghost w-full sm:w-auto">
          {d.hero.cta_secondary}
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>

      <div class="mt-5 flex justify-center">
        <div class="command-pill">
          <span class="select-none text-zinc-500">$</span>
          <code class="truncate">{d.cta.command}</code>
        </div>
      </div>
    </div>

    <div class="relative mx-auto mt-14 max-w-6xl lg:mt-20">
      <div class="pointer-events-none absolute -inset-8 -z-10 rounded-[3rem] bg-gradient-brand opacity-20 blur-3xl"></div>
      <div class="surface-soft overflow-hidden p-2 sm:p-3">
        <Terminal
          client:load
          scenarios={d.terminal.scenarios}
          tabs={d.terminal.tabs}
          breadcrumb={d.terminal.breadcrumb}
          status={d.terminal.status}
        />
      </div>
    </div>

    <div class="mx-auto mt-10 max-w-4xl text-center">
      <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-zinc-500">{d.hero.trust_lead}</p>
      <div class="mt-4 flex flex-wrap items-center justify-center gap-x-7 gap-y-3 text-sm font-semibold tracking-tight text-zinc-400">
        {trustLogos.map((p) => (
          <span class="transition hover:text-white">{p}</span>
        ))}
      </div>
    </div>
  </div>
</section>
