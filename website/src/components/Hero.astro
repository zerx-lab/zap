---
import { t, type Locale } from '../i18n';
import Terminal from './Terminal.tsx';

interface Props { locale: Locale }
const { locale } = Astro.props;
const d = t(locale);

const trustLogos = ['OpenAI', 'Anthropic', 'DeepSeek', 'Qwen', 'Ollama', 'Groq'];
---

<section class="relative pt-24 pb-20 lg:pt-32 lg:pb-28">
  <div class="container-page">
    <div class="grid items-center gap-14 lg:grid-cols-12">
      <div class="lg:col-span-6">
        <span class="glass-pill">
          <span class="relative inline-flex h-1.5 w-1.5">
            <span class="absolute inset-0 rounded-full bg-accent-lime opacity-75 animate-ping"></span>
            <span class="relative h-1.5 w-1.5 rounded-full bg-accent-lime"></span>
          </span>
          {d.hero.badge}
        </span>

        <h1 class="mt-7 font-display text-[32px] font-semibold leading-[1.08] tracking-tight text-white sm:text-[56px] sm:leading-[1.05] lg:text-[72px]">
          {d.hero.title_1}
          <span class="block sm:inline text-accent">{d.hero.title_em}</span>
          {d.hero.title_2}
        </h1>

        <p class="mt-6 max-w-xl text-base text-zinc-400 sm:mt-7 sm:text-lg">{d.hero.subtitle}</p>

        <div class="mt-8 flex flex-wrap items-center gap-2 sm:mt-10 sm:gap-3">
          <a href="https://github.com/zerx-lab/warp/tree/openWarp" target="_blank" rel="noreferrer" class="btn-primary group">
            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.18c-3.2.7-3.87-1.37-3.87-1.37-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.15 1.17.91-.25 1.89-.38 2.86-.39.97.01 1.95.14 2.86.39 2.19-1.48 3.15-1.17 3.15-1.17.62 1.59.23 2.76.11 3.05.74.8 1.18 1.82 1.18 3.08 0 4.42-2.69 5.4-5.25 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/></svg>
            {d.hero.cta_primary}
          </a>
          <a href="#providers" class="btn-ghost">
            {d.hero.cta_secondary}
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>

        <p class="mt-5 text-xs text-zinc-500">{d.hero.note}</p>

        <div class="mt-10 border-t border-white/5 pt-6">
          <p class="text-[11px] font-medium uppercase tracking-[0.18em] text-zinc-500">{d.hero.trust_lead}</p>
          <div class="mt-4 flex flex-wrap items-center gap-x-6 gap-y-2 text-zinc-300">
            {trustLogos.map((p) => (
              <span class="text-sm font-semibold tracking-tight text-zinc-400/90 transition hover:text-white">{p}</span>
            ))}
          </div>
        </div>
      </div>

      <div class="lg:col-span-6">
        <div class="relative">
          <div class="absolute -inset-6 -z-10 rounded-[2rem] bg-brand-500/10 blur-3xl"></div>
          <Terminal
            client:load
            scenarios={d.terminal.scenarios}
            tabs={d.terminal.tabs}
            breadcrumb={d.terminal.breadcrumb}
            status={d.terminal.status}
          />
        </div>
      </div>
    </div>
  </div>
</section>
