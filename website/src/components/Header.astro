---
import { t, type Locale, localizedPath, localeLabels, locales } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);
---

<header class="sticky top-0 z-40 border-b border-white/5 bg-ink-950/70 backdrop-blur-md">
  <div class="container-page flex h-16 items-center justify-between">
    <a href={localizedPath(locale, '/')} class="flex items-center gap-2.5 group">
      <span class="inline-flex h-7 w-7 items-center justify-center rounded-md border border-white/10 bg-white/[0.04]">
        <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 text-white" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m6 8 4 4-4 4"/>
          <path d="M13 16h5"/>
        </svg>
      </span>
      <span class="font-display text-[16px] font-semibold tracking-tight text-white">OpenWarp</span>
    </a>

    <nav class="hidden items-center gap-8 md:flex">
      <a href="#how"       class="text-sm text-zinc-400 transition hover:text-white">{dict.nav.how}</a>
      <a href="#features"  class="text-sm text-zinc-400 transition hover:text-white">{dict.nav.features}</a>
      <a href="#providers" class="text-sm text-zinc-400 transition hover:text-white">{dict.nav.providers}</a>
      <a href="#faq"       class="text-sm text-zinc-400 transition hover:text-white">{dict.nav.faq}</a>
    </nav>

    <div class="flex items-center gap-2">
      <div class="hidden items-center gap-1 rounded-full border border-white/10 bg-white/[0.03] p-1 text-xs sm:inline-flex">
        {locales.map((lc) => (
          <a
            href={localizedPath(lc, '/')}
            class:list={[
              'rounded-full px-3 py-1 transition',
              lc === locale
                ? 'bg-white/10 text-white'
                : 'text-zinc-400 hover:text-white',
            ]}
          >{localeLabels[lc]}</a>
        ))}
      </div>
      <a
        href="https://github.com/zerx-lab/warp"
        target="_blank"
        rel="noreferrer"
        class="btn-ghost"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.18c-3.2.7-3.87-1.37-3.87-1.37-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.15 1.17.91-.25 1.89-.38 2.86-.39.97.01 1.95.14 2.86.39 2.19-1.48 3.15-1.17 3.15-1.17.62 1.59.23 2.76.11 3.05.74.8 1.18 1.82 1.18 3.08 0 4.42-2.69 5.4-5.25 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
        </svg>
        GitHub
      </a>
    </div>
  </div>
</header>
