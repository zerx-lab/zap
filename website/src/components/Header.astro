---
import { t, type Locale, localizedPath, localeLabels, locales } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-ink-950/75 backdrop-blur-2xl">
  <div class="hidden border-b border-white/10 bg-white/[0.03] sm:block">
    <div class="container-page flex h-9 items-center justify-center gap-2 text-center text-[12px] text-zinc-400">
      <span class="inline-flex h-1.5 w-1.5 rounded-full bg-accent-lime shadow-[0_0_16px_rgba(185,255,90,0.75)]"></span>
      <span class="text-zinc-300">{dict.hero.badge}</span>
      <span class="text-zinc-600">·</span>
      <a href="https://github.com/zerx-lab/warp" target="_blank" rel="noreferrer" class="transition hover:text-white">
        {dict.hero.note}
      </a>
    </div>
  </div>

  <div class="container-page flex h-16 items-center justify-between gap-4">
    <a href={localizedPath(locale, '/')} class="group flex items-center gap-3">
      <span class="relative flex h-9 w-9 items-center justify-center overflow-hidden rounded-xl border border-white/10 bg-white/[0.06] shadow-card">
        <img src="/logo-mono.svg" alt="OpenWarp" class="h-7 w-7 object-contain" />
      </span>
      <span class="font-display text-[16px] font-semibold tracking-tight text-white">OpenWarp</span>
    </a>

    <nav class="hidden items-center gap-1 rounded-full border border-white/10 bg-white/[0.035] p-1 md:flex">
      <a href="#how" class="rounded-full px-4 py-2 text-sm text-zinc-400 transition hover:bg-white/[0.06] hover:text-white">{dict.nav.how}</a>
      <a href="#features" class="rounded-full px-4 py-2 text-sm text-zinc-400 transition hover:bg-white/[0.06] hover:text-white">{dict.nav.features}</a>
      <a href="#providers" class="rounded-full px-4 py-2 text-sm text-zinc-400 transition hover:bg-white/[0.06] hover:text-white">{dict.nav.providers}</a>
      <a href="#faq" class="rounded-full px-4 py-2 text-sm text-zinc-400 transition hover:bg-white/[0.06] hover:text-white">{dict.nav.faq}</a>
      <a href={localizedPath(locale, '/roadmap')} class="rounded-full px-4 py-2 text-sm text-zinc-400 transition hover:bg-white/[0.06] hover:text-white">{dict.footer.roadmap}</a>
    </nav>

    <div class="flex items-center gap-2">
      <div class="hidden items-center gap-1 rounded-full border border-white/10 bg-white/[0.035] p-1 text-xs sm:inline-flex">
        {locales.map((lc) => (
          <a
            href={localizedPath(lc, '/')}
            data-locale-switch={lc}
            class:list={[
              'rounded-full px-3 py-1.5 transition',
              lc === locale
                ? 'bg-white text-ink-950'
                : 'text-zinc-400 hover:text-white',
            ]}
          >{localeLabels[lc]}</a>
        ))}
      </div>
      <a
        href="https://github.com/zerx-lab/warp"
        target="_blank"
        rel="noreferrer"
        class="btn-ghost !px-4 !py-2"
        aria-label="GitHub"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.18c-3.2.7-3.87-1.37-3.87-1.37-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.15 1.17.91-.25 1.89-.38 2.86-.39.97.01 1.95.14 2.86.39 2.19-1.48 3.15-1.17 3.15-1.17.62 1.59.23 2.76.11 3.05.74.8 1.18 1.82 1.18 3.08 0 4.42-2.69 5.4-5.25 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
        </svg>
        <span class="hidden sm:inline">{dict.nav.github}</span>
      </a>
    </div>
  </div>
</header>
